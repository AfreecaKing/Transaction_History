@model ValidationResultViewModel
@{
    ViewData["Title"] = "交易驗證";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>交易驗證－@Model.PoolName</h2>
        <a asp-action="Detail"
           asp-controller="FundPool"
           asp-route-id="@Model.FundPoolId"
           class="btn btn-secondary">
            返回
        </a>
    </div>

    <div class="alert alert-danger">
        <h5 class="alert-heading">❌ 發現 @Model.Errors.Count 個問題</h5>
        <p class="mb-0">請修正以下交易紀錄後再進行計算。</p>
    </div>

    <div class="card">
        <div class="card-header bg-danger text-white">
            問題清單
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>時間</th>
                        <th>類型</th>
                        <th>問題描述</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var error in Model.Errors)
                    {
                        <tr class="table-danger">
                            <td>
                                @(error.TransactionTime == default
                                                            ? "-"
                                                            : error.TransactionTime.ToString("yyyy/MM/dd"))
                        </td>
                        <td>
                            @if (error.TransactionTime != default)
                                {
                                    <span class="badge bg-danger">@error.Type</span>
                                }
                            </td>
                            <td>@error.ErrorMessage</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>