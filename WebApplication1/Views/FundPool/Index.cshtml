@model IEnumerable<FundPool>
@{
    ViewData["Title"] = "資金池管理";
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
}

<div class="container d-flex flex-column justify-content-center" style="min-height: 85vh; padding-top: 8vh;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        @*水平排列、左右兩端對齊、垂直居中*@
        <h2>資金池管理</h2>
        <a class="btn btn-primary" asp-action="CreatePool" asp-controller="FundPool">
            新增資金池
        </a>
    </div>

    <div class="row g-4" style="min-height: 460px; align-content: start;">
        @foreach (var pool in Model)
        {
            <div class="col-12 col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title">@pool.PoolName</h5>
                        <hr>
                        <p>建立時間：@pool.CreateTime.ToString("yyyy/MM/dd")</p>
                    </div>
                    <div class="card-footer bg-white border-0">
                        <a asp-action="Detail"
                           asp-controller="FundPool"
                           asp-route-id="@pool.FundPoolId"
                           class="btn btn-outline-primary btn-sm">
                            查看詳細
                        </a>
                        <form asp-action="Delete"
                              asp-controller="FundPool"
                              asp-route-id="@pool.FundPoolId"
                              method="post"
                              style="display:inline">
                            @Html.AntiForgeryToken()
                            <button type="submit"
                                    class="btn btn-outline-danger btn-sm"
                                    onclick="return confirm('確定刪除此資金池？所有交易紀錄也會一併刪除！')">
                                刪除
                            </button>
                        </form>
                    </div>
                  
                </div>
            </div>
        }
        @if (!Model.Any())
        {
            <div class="col-12 text-center text-muted mt-4">
                <p>目前沒有資金池，點擊右上角新增吧！</p>
            </div>
        }
    </div>

    @* pagination 永遠在最底部 *@
    @if (Model.Any())
    {
        <nav class="mt-5">
            <ul class="pagination justify-content-center">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-controller="FundPool"
                       asp-route-page="@(currentPage - 1)">
                        &laquo;
                    </a>
                </li>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-controller="FundPool"
                           asp-route-page="@i">
                            @i
                        </a>
                    </li>
                }
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-controller="FundPool"
                       asp-route-page="@(currentPage + 1)">
                        &raquo;
                    </a>
                </li>
            </ul>
        </nav>
    }

</div>