@{
    ViewData["Title"] = "新增資金池";
}

<div class="container mt-4">

    <h2 class="mb-4">新增資金池</h2>

    <form>

        <div class="mb-3">
            <label class="form-label">資金池名稱</label>

            <input type="text"
                   class="form-control"
                   placeholder="例如：台股1號">
        </div>

        <button class="btn btn-primary">
            建立
        </button>

        <a href="#" class="btn btn-secondary">
            取消
        </a>

    </form>

</div>