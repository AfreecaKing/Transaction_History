@{
    ViewData["Title"] = "新增資金池";
}
<div class="container mt-4">
    <h2 class="mb-4">新增資金池</h2>
    <form asp-action="Create" asp-controller="FundPool" method="post">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label class="form-label">資金池名稱</label>
            <input type="text"
                   name="poolName"
                   class="form-control"
                   placeholder="例如：台股1號"
                   required>
        </div>
        <input type="hidden" name="currentValue" value="0" />
        <button type="submit" class="btn btn-primary">建立</button>
        <a asp-action="Index" asp-controller="FundPool" class="btn btn-secondary">取消</a>
    </form>
</div>