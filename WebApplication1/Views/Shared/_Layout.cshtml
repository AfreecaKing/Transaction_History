@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebApplication1</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApplication1.styles.css" asp-append-version="true" />
</head>
<body class="bg-dark text-white">
    <header>
        @*
            nav class:
           - 加上 rounded-pill：把整條導覽列的左、右兩端變成橢圓形
           - 加上 px-4：讓導覽列內部的東西往內縮
           - shadow-sm：加上陰影
        *@
        <div class="container-fluid mt-2 px-4">
            <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-opacity-10 bg-white border border-light box-shadow  rounded-pill px-4 mb-3 shadow-sm">
                <!--寬度調到100%-->
                <div class="container-fluid">
                    <a class="navbar-brand text-white" asp-area="" asp-controller="Home" asp-action="Index">報酬計算</a>
                    <button class="navbar-toggler " type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                        @*用ms-auto將登入鍵靠右 下面分為登入和未登入狀態的按鈕顯示*@
                        <ul class="navbar-nav ms-auto align-items-center">
                            @*已登入*@
                            @if (Context.Session.GetString("UserName")!=null)
                            {
                                <!-- Navbar 的下拉選單 -->
                                <li class="nav-item dropdown">
                                    <!-- 點擊後展開 dropdown 的按鈕 -->
                                    <a class="nav-link dropdown-toggle text-light" href="#" id="userDropdown" role="button"
                                    data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="fa-solid fa-user me-1"></i> @Context.Session.GetString("UserName")
                                    </a>
                                    <!-- 下拉選單內容（靠右 + 陰影效果） -->
                                    <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="userDropdown">
                                        <li>
                                            @* Account/Logout Function *@
                                            <a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">
                                                <i class="fa-solid fa-right-from-bracket me-1"></i> 登出
                                            </a>
                                        </li>
                                    </ul>
                                </li>

                            }
                            @*未登入*@
                            else 
                            {
                                @* 
                                - btn: 讓它具備按鈕的立體與點擊效果
                                - btn-outline-dark: 變成黑色細線外框
                                - rounded-pill: 把邊角變成膠囊狀
                                - px-4: 增加左右的留白寬度
                                *@
                                <li class="nav-item me-2">                           
                                    <a class="btn btn-outline-light rounded-pill px-3 " asp-controller="Account" asp-action="Login">登入</a>
                                </li>
                                <li class="nav-item">
                                    <a class="btn btn-outline-light rounded-pill px-3" asp-controller="Account" asp-action="Register">註冊</a>
                                </li>                               
                            }                  
                        </ul>
                    </div>
                </div>
            </nav>
        </div>   
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    
   
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
