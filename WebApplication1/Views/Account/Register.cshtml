@model WebApplication1.Models.User

@* 外層容器：使用 Bootstrap 樣式設定置中、置頂外距(mt-5)，並限制最大寬度為 400 像素 *@
<div class="container mt-5" style="max-width: 400px;">
    <h2>會員註冊</h2>
    <hr />
    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }
    @* 註冊區域 *@
    <form asp-action="Register" method="post">
        @* 輸入區塊：使用者名稱 *@
        <div class="mb-3">
            <label class="form-label">使用者名稱</label>
            <input asp-for="Name" type="text" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        @* 輸入區塊：密碼 *@
        <div class="mb-3">
            <label class="form-label">密碼</label>
            <input asp-for="Password" type="password" class="form-control"/>
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>
        @* 提交按鈕：type="submit" 點擊後觸發表單送出，btn-primary 為藍色按鈕，w-100 為全寬 *@
        <button type="submit" class="btn btn-primary w-100">註冊</button>
    </form>
    @* 頁面跳轉超連結指向該 Controller 下 Login 頁面的正確 URL。*@
    <p class="mt-3 text-center"><a asp-action="Login">已有帳號？前往登入</a></p>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}